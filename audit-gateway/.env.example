# AI Audit Gateway 环境变量配置

# 应用配置
APP_NAME=AI Audit Gateway
DEBUG=false
LOG_LEVEL=INFO

# 服务配置
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ClickHouse 数据库配置
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=ai_audit
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 审计配置
AUDIT_BATCH_SIZE=1000
AUDIT_FLUSH_INTERVAL=5

# 敏感词检测
ENABLE_SENSITIVE_CHECK=true
SENSITIVE_WORDS_FILE=sensitive_words.txt

# 告警配置（可选）
# ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
ALERT_THRESHOLD_HIGH=10

# 安全密钥（生产环境必须修改！）
API_SECRET_KEY=your-secret-key-change-this-in-production
ADMIN_TOKEN=your-admin-token-change-this-in-production
